#!/usr/bin/env bash
# ~/.bash_roest_github
#
# Interactive GitHub management — fzf-powered screens
# Source this from .bashrc:
#   source ~/.bash_roest_github
#
# Commands:
#   gh-ui         Unified hub → all GitHub & Actions tools (with live preview)
#   gpr           Interactive PR management (list → pick → act)
#   gpr create    Create a new PR from current branch
#   gpr mine      Show only your PRs
#   ghsecrets     Manage repo & environment secrets
#   ghbranch      Branch management & protection rules
#   ghenv         Environment management
#
# Navigation:
#   Menus:  ↑↓ navigate  enter select  -/q back
#   Lists:  type to search  enter select  esc back
#   Pagers: r refresh  -/q back
#
# Dependencies: gh, fzf, jq

# ─── Helpers ──────────────────────────────────────────────────────

__gh_check() {
  if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    echo "❌ Not in a git repository" >&2
    return 1
  fi
  if ! command -v gh &>/dev/null; then
    echo "❌ gh CLI not installed (brew install gh)" >&2
    return 1
  fi
  if ! command -v fzf &>/dev/null; then
    echo "❌ fzf not installed (brew install fzf)" >&2
    return 1
  fi
}

__gh_repo() {
  gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null
}

__gh_default_branch() {
  gh repo view --json defaultBranchRef -q .defaultBranchRef.name 2>/dev/null
}

# Picks a remote branch via fzf (searchable — branch names contain -)
__gh_pick_branch() {
  local header="${1:-Select branch}"
  git branch -r 2>/dev/null \
    | sed 's|origin/||; s|^[[:space:]]*||' \
    | grep -v '^HEAD' \
    | sort -u \
    | fzf --header="$header  │  type to filter  enter select  esc back" --height=15
}

# ─────────────────────────────────────────────────────────────────
#  gh-ui — Unified GitHub Hub
# ─────────────────────────────────────────────────────────────────

gh-ui() {
  __gh_check || return 1

  local repo
  repo=$(__gh_repo)

  # ─── Pre-fetch preview data in parallel ───────────────────────
  local tmpdir
  tmpdir=$(mktemp -d /tmp/gh-ui-XXXXXX)

  # Run all fetches inside a single subshell to suppress job control
  # notifications and prevent any output from leaking to the terminal
  (
    gh pr list --limit 8 --state open \
      --json number,title,reviewDecision,isDraft,author \
      --jq '.[] | "#\(.number)  \(
        if .isDraft then "📝"
        elif .reviewDecision == "APPROVED" then "✅"
        elif .reviewDecision == "CHANGES_REQUESTED" then "🔄"
        else "⏳" end)  \(.title)  (\(.author.login))"' \
      > "$tmpdir/prs" 2>/dev/null &

    gh pr list --limit 8 --state open --author=@me \
      --json number,title,reviewDecision,isDraft \
      --jq '.[] | "#\(.number)  \(
        if .isDraft then "📝"
        elif .reviewDecision == "APPROVED" then "✅"
        elif .reviewDecision == "CHANGES_REQUESTED" then "🔄"
        else "⏳" end)  \(.title)"' \
      > "$tmpdir/mine" 2>/dev/null &

    {
      branch=$(git symbolic-ref --short HEAD 2>/dev/null || echo "(detached)")
      default_br=$(gh repo view --json defaultBranchRef -q .defaultBranchRef.name 2>/dev/null)
      echo "Branch: $branch → $default_br"
      unpushed=$(git log --oneline "@{u}..HEAD" 2>/dev/null | head -5)
      if [[ -n "$unpushed" ]]; then
        count=$(git log --oneline "@{u}..HEAD" 2>/dev/null | wc -l)
        echo "$count unpushed commit(s):"
        echo "$unpushed"
      else
        echo "(no unpushed commits)"
      fi
    } > "$tmpdir/branch" 2>/dev/null &

    {
      repo_ci=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null)
      sha_ci=$(git rev-parse HEAD 2>/dev/null)
      gh api "repos/$repo_ci/commits/$sha_ci/check-runs" 2>/dev/null \
        | jq -r '.check_runs[] | [.name, (if .status == "completed" then (if .conclusion == "success" then "✅" elif .conclusion == "failure" then "❌" elif .conclusion == "skipped" then "⏭" else "❓" end) else "⏳" end), (.completed_at // .started_at // "")] | @tsv' 2>/dev/null \
        | while IFS=$'\t' read -r name status ts; do
            local age=""
            [[ -n "$ts" ]] && age=$(__relative_time "$ts")
            printf "%-40s %s  %s\n" "$name" "$status" "${age:-}"
          done
    } > "$tmpdir/ci" 2>/dev/null &

    gh secret list > "$tmpdir/secrets" 2>/dev/null &

    gh api "repos/$repo/environments" \
      --jq '.environments[] | "\(.name)   created: \(.created_at[:10])"' \
      > "$tmpdir/envs" 2>/dev/null &

    gh api "repos/$repo/branches" --paginate \
      --jq '.[] | "\(if .protected then "🛡 " else "   " end)\(.name)\(if .protected then "  (protected)" else "" end)"' \
      > "$tmpdir/branches" 2>/dev/null &

    wait
  ) 2>/dev/null

  # ─── Hub menu with live preview ───────────────────────────────
  local action
  action=$(printf '%s\n' \
    "🔀 Pull Requests" \
    "📋 Pull Requests (mine)" \
    "➕ Create Pull Request" \
    "─────────────────────────────" \
    "🚀 CI / Actions" \
    "─────────────────────────────" \
    "🔑 Secrets" \
    "🌍 Environments" \
    "🌿 Branches" \
    | fzf --disabled --bind 'q:abort,-:abort' \
        --header="GitHub — $repo  │  ↑↓ nav  enter select  -/q exit" \
        --preview "case {} in
          *'Pull Requests (mine)'*) cat $tmpdir/mine 2>/dev/null || echo '(none)' ;;
          *'Pull Requests'*) cat $tmpdir/prs 2>/dev/null || echo '(none)' ;;
          *'Create'*) cat $tmpdir/branch 2>/dev/null ;;
          *'CI'*) cat $tmpdir/ci 2>/dev/null ;;
          *'Secrets'*) cat $tmpdir/secrets 2>/dev/null ;;
          *'Environments'*) cat $tmpdir/envs 2>/dev/null || echo '(none)' ;;
          *'Branches'*) cat $tmpdir/branches 2>/dev/null || echo '(none)' ;;
          *) echo '' ;;
        esac" \
        --preview-window=right:50%:wrap --no-info)

  rm -rf "$tmpdir"

  [[ -z "$action" || "$action" == *"───"* ]] && return

  case "$action" in
    *"Pull Requests (mine)"*)  gpr mine ;;
    *"Create Pull Request"*)   gpr create ;;
    *"Pull Requests"*)         gpr ;;
    *"CI / Actions"*)          gha-ui ;;
    *"Secrets"*)               ghsecrets ;;
    *"Environments"*)          ghenv ;;
    *"Branches"*)              ghbranch ;;
  esac

  gh-ui
}

# ─────────────────────────────────────────────────────────────────
#  gpr — Interactive Pull Request Management
# ─────────────────────────────────────────────────────────────────

gpr() {
  __gh_check || return 1

  case "${1:-}" in
    create) _gpr_create; return ;;
    mine)   _gpr_list "--author=@me"; return ;;
  esac

  # Filter picker for bare `gpr`
  local filter
  filter=$(printf '%s\n' \
    "📋 All open PRs" \
    "👀 Needs my review" \
    "📝 My PRs" \
    "─────────────────────────────" \
    "🔒 Recently closed" \
    "✅ Recently merged" \
    | fzf --disabled --bind 'q:abort,-:abort' \
        --header="Pull Requests  │  ↑↓ nav  enter select  -/q back" \
        --height=9 --no-info)

  [[ -z "$filter" || "$filter" == *"───"* ]] && return

  case "$filter" in
    *"All open"*)        _gpr_list ;;
    *"Needs my review"*) _gpr_list "--search review-requested:@me" ;;
    *"My PRs"*)          _gpr_list "--author=@me" ;;
    *"Recently closed"*) _gpr_list "--state closed" ;;
    *"Recently merged"*) _gpr_list "--state merged" ;;
  esac
}

# ─── Create PR ────────────────────────────────────────────────────

_gpr_create() {
  local current_branch default_branch
  current_branch=$(git symbolic-ref --short HEAD 2>/dev/null)
  default_branch=$(__gh_default_branch)

  if [[ "$current_branch" == "$default_branch" ]]; then
    echo "❌ You're on '$default_branch' — switch to a feature branch first"
    return 1
  fi

  echo "━━━ Create Pull Request ━━━"
  echo ""
  echo "  📌 Source: $current_branch → $default_branch"

  local unpushed
  unpushed=$(git log --oneline "@{u}..HEAD" 2>/dev/null)
  if [[ -n "$unpushed" ]]; then
    local count
    count=$(echo "$unpushed" | wc -l)
    echo "  📤 $count unpushed commit(s):"
    echo "$unpushed" | sed 's/^/       /'
    echo ""
  fi

  local draft_flag=""
  local choice
  choice=$(printf '%s\n' "Ready for review" "Draft" \
    | fzf --disabled --bind 'q:abort,-:abort' \
        --header="PR type:  │  ↑↓ nav  enter select  -/q back" --height=5 --no-info)
  [[ -z "$choice" ]] && return
  [[ "$choice" == "Draft" ]] && draft_flag="--draft"

  echo ""
  gh pr create $draft_flag
}

# ─── List & pick PRs ─────────────────────────────────────────────

_gpr_list() {
  local extra_flags="${1:-}"

  local pr_lines
  pr_lines=$(gh pr list --limit 50 --state open $extra_flags \
    --json number,title,author,headRefName,reviewDecision,additions,deletions,isDraft,createdAt \
    --jq '.[] | [
      .number,
      (if .isDraft then "DRAFT"
       elif .reviewDecision == "APPROVED" then "APPROVED"
       elif .reviewDecision == "CHANGES_REQUESTED" then "CHANGES"
       else "PENDING" end),
      .title,
      .author.login,
      .headRefName,
      "+\(.additions)/-\(.deletions)",
      .createdAt
    ] | @tsv' 2>/dev/null)

  if [[ -z "$pr_lines" ]]; then
    echo "No open PRs found."
    return
  fi

  local formatted_prs
  formatted_prs=$(echo "$pr_lines" | while IFS=$'\t' read -r num status title author branch changes created; do
    local emoji age
    case "$status" in
      APPROVED) emoji="✅" ;;
      CHANGES)  emoji="🔄" ;;
      DRAFT)    emoji="📝" ;;
      *)        emoji="⏳" ;;
    esac
    age=$(__relative_time "$created")
    printf "#%-5s %s %-10s  %-48.48s  %-10s  %-22.22s  %s  %s\n" \
      "$num" "$emoji" "$status" "$title" "$author" "$branch" "$changes" "${age:-}"
  done)

  local selection
  selection=$(echo "$formatted_prs" \
    | fzf --ansi --no-sort \
        --header="  PR     Status       Title                                              Author      Branch                  Changes  Age
$(printf '─%.0s' {1..130})
  type to filter  │  enter=actions  esc=back" \
        --preview 'gh pr view $(echo {} | awk "{print \$1}" | tr -d "#")' \
        --preview-window=right:50%:wrap)

  [[ -z "$selection" ]] && return

  local pr_number
  pr_number=$(echo "$selection" | awk '{print $1}' | tr -d '#')

  _gpr_actions "$pr_number"
}

# ─── Action menu for a selected PR ───────────────────────────────

_gpr_actions() {
  local number="$1"
  local pr_title
  pr_title=$(gh pr view "$number" --json title -q .title 2>/dev/null)

  local action
  action=$(printf '%s\n' \
    "👁  View details" \
    "📥 Checkout locally" \
    "📝 View diff" \
    "📊 View file changes" \
    "💬 Add comment" \
    "✅ Approve" \
    "🔄 Request changes" \
    "🏷  Manage labels" \
    "👤 Request reviewers" \
    "✏️  Edit title/body" \
    "🔀 Merge" \
    "❌ Close PR" \
    "🌐 Open in browser" \
    "🔍 View CI checks" \
    | fzf --disabled --bind 'q:abort,-:abort' \
        --no-info \
        --header="PR #${number}: ${pr_title}  │  ↑↓ nav  enter select  -/q back")

  [[ -z "$action" ]] && return

  case "$action" in
    *"View details"*)
      gh pr view "$number"
      echo ""
      local key; read -rsn1 -p "  r=refresh  -/q=back " key; echo ""
      [[ "$key" == "r" || "$key" == "R" ]] && { _gpr_actions "$number"; return; }
      _gpr_actions "$number"
      ;;

    *"Checkout"*)
      gh pr checkout "$number"
      echo "✅ Checked out PR #${number} locally"
      ;;

    *"View diff"*)
      gh pr diff "$number" --color=always | less -R
      _gpr_actions "$number"
      ;;

    *"View file changes"*)
      _gpr_files "$number"
      _gpr_actions "$number"
      ;;

    *"Add comment"*)
      _gpr_comment "$number"
      _gpr_actions "$number"
      ;;

    *"Approve"*)
      local msg=""
      read -rp "Approval message (optional, enter to skip): " msg
      if [[ -n "$msg" ]]; then
        gh pr review "$number" --approve --body "$msg"
      else
        gh pr review "$number" --approve
      fi
      echo "✅ PR #${number} approved"
      _gpr_actions "$number"
      ;;

    *"Request changes"*)
      echo "Enter feedback (opens editor if EDITOR is set, otherwise type below):"
      local feedback
      if [[ -n "${EDITOR:-}" ]]; then
        local tmpfile
        tmpfile=$(mktemp /tmp/pr-review-XXXXXX.md)
        $EDITOR "$tmpfile"
        feedback=$(cat "$tmpfile")
        rm -f "$tmpfile"
      else
        echo "(Ctrl+D when done, Ctrl+C to cancel)"
        feedback=$(cat)
      fi
      if [[ -n "$feedback" ]]; then
        gh pr review "$number" --request-changes --body "$feedback"
        echo "✅ Changes requested on PR #${number}"
      fi
      _gpr_actions "$number"
      ;;

    *"Manage labels"*)
      _gpr_labels "$number"
      _gpr_actions "$number"
      ;;

    *"Request reviewers"*)
      _gpr_reviewers "$number"
      _gpr_actions "$number"
      ;;

    *"Edit title"*)
      _gpr_edit "$number"
      _gpr_actions "$number"
      ;;

    *"Merge"*)
      _gpr_merge "$number"
      ;;

    *"Close PR"*)
      read -rp "Close PR #${number}? (y/N): " confirm
      if [[ "$confirm" =~ ^[yY]$ ]]; then
        gh pr close "$number"
        echo "✅ PR #${number} closed"
      fi
      ;;

    *"Open in browser"*)
      gh pr view "$number" --web
      _gpr_actions "$number"
      ;;

    *"CI checks"*)
      local checks
      checks=$(gh pr checks "$number" 2>/dev/null)
      if [[ -z "$checks" ]]; then
        echo "  No checks found"
        sleep 1
      else
        local pick
        pick=$(echo "$checks" \
          | fzf --ansi \
              --header="CI for PR #${number}  │  enter=view logs  esc=back" \
              --preview 'echo {}' --preview-window=right:50%:wrap)
        if [[ -n "$pick" ]]; then
          local check_url run_id check_name
          check_url=$(echo "$pick" | awk '{print $NF}')
          run_id=$(echo "$check_url" | sed -n 's|.*/runs/\([0-9]*\).*|\1|p')
          check_name=$(echo "$pick" | awk '{print $1}')
          if [[ -n "$run_id" ]]; then
            _gha_action_menu "$run_id" "$check_name" "$check_url"
          else
            _open_url "$check_url"
          fi
        fi
      fi
      _gpr_actions "$number"
      ;;
  esac
}

# ─── Browse changed files in a PR ────────────────────────────────

_gpr_files() {
  local number="$1"

  local file
  file=$(gh pr diff "$number" --name-only 2>/dev/null \
    | fzf --header="Changed files in PR #${number}  │  enter=view diff  esc=back" \
        --preview "gh pr diff $number -- {} --color=always" \
        --preview-window=right:60%:wrap)

  if [[ -n "$file" ]]; then
    gh pr diff "$number" -- "$file" --color=always | less -R
  fi
}

# ─── Comment on a PR ─────────────────────────────────────────────

_gpr_comment() {
  local number="$1"

  local method
  method=$(printf '%s\n' "Type inline" "Open in editor" \
    | fzf --disabled --bind 'q:abort,-:abort' \
        --header="How to write your comment?  │  ↑↓ nav  enter select  -/q back" \
        --height=5 --no-info)

  [[ -z "$method" ]] && return

  local body=""
  case "$method" in
    *"inline"*)
      echo "Enter comment (Ctrl+D when done):"
      body=$(cat)
      ;;
    *"editor"*)
      local tmpfile
      tmpfile=$(mktemp /tmp/pr-comment-XXXXXX.md)
      ${EDITOR:-vi} "$tmpfile"
      body=$(cat "$tmpfile")
      rm -f "$tmpfile"
      ;;
  esac

  if [[ -n "$body" ]]; then
    gh pr comment "$number" --body "$body"
    echo "✅ Comment added to PR #${number}"
  fi
}

# ─── Merge a PR ──────────────────────────────────────────────────

_gpr_merge() {
  local number="$1"

  local mergeable
  mergeable=$(gh pr view "$number" --json mergeable -q .mergeable 2>/dev/null)
  if [[ "$mergeable" == "CONFLICTING" ]]; then
    echo "⚠️  PR has merge conflicts — resolve before merging"
    return
  fi

  local strategy
  strategy=$(printf '%s\n' \
    "Squash and merge  (recommended: clean history)" \
    "Merge commit      (preserves all commits)" \
    "Rebase and merge  (linear history, no merge commit)" \
    | fzf --disabled --bind 'q:abort,-:abort' \
        --header="Merge strategy for PR #${number}  │  ↑↓ nav  enter select  -/q back" \
        --height=6 --no-info)

  [[ -z "$strategy" ]] && return

  local flag
  case "$strategy" in
    *Squash*)  flag="--squash" ;;
    *commit*)  flag="--merge" ;;
    *Rebase*)  flag="--rebase" ;;
  esac

  local delete_flag=""
  read -rp "Delete branch after merge? (Y/n): " del
  [[ ! "$del" =~ ^[nN]$ ]] && delete_flag="--delete-branch"

  gh pr merge "$number" $flag $delete_flag \
    && echo "✅ PR #${number} merged" \
    || echo "❌ Merge failed — check requirements"
}

# ─── Labels ───────────────────────────────────────────────────────

_gpr_labels() {
  local number="$1"

  local current
  current=$(gh pr view "$number" --json labels --jq '.labels[].name' 2>/dev/null)
  echo "Current labels: ${current:-none}"
  echo ""

  local action
  action=$(printf '%s\n' "Add label" "Remove label" \
    | fzf --disabled --bind 'q:abort,-:abort' \
        --header="Labels for PR #${number}  │  ↑↓ nav  enter select  -/q back" \
        --height=5 --no-info)

  [[ -z "$action" ]] && return

  case "$action" in
    "Add label")
      local available
      available=$(gh label list --json name --jq '.[].name' 2>/dev/null)
      if [[ -z "$available" ]]; then
        echo "No labels in this repo. Create them on GitHub first."
        return
      fi
      local labels
      labels=$(echo "$available" \
        | fzf --multi --header="Select labels (TAB toggle, ENTER confirm)  │  esc=back")
      if [[ -n "$labels" ]]; then
        local joined
        joined=$(echo "$labels" | paste -sd,)
        gh pr edit "$number" --add-label "$joined" && echo "✅ Added: $joined"
      fi
      ;;
    "Remove label")
      if [[ -z "$current" ]]; then
        echo "No labels to remove"
        return
      fi
      local labels
      labels=$(echo "$current" \
        | fzf --multi --header="Select labels to remove (TAB toggle, ENTER confirm)  │  esc=back")
      if [[ -n "$labels" ]]; then
        local joined
        joined=$(echo "$labels" | paste -sd,)
        gh pr edit "$number" --remove-label "$joined" && echo "✅ Removed: $joined"
      fi
      ;;
  esac
}

# ─── Reviewers ────────────────────────────────────────────────────

_gpr_reviewers() {
  local number="$1"
  local repo
  repo=$(__gh_repo)

  local collabs
  collabs=$(gh api "repos/$repo/collaborators" --jq '.[].login' 2>/dev/null)

  if [[ -n "$collabs" ]]; then
    local reviewers
    reviewers=$(echo "$collabs" \
      | fzf --multi --header="Select reviewers (TAB toggle, ENTER confirm)  │  esc=back")
    if [[ -n "$reviewers" ]]; then
      local joined
      joined=$(echo "$reviewers" | paste -sd,)
      gh pr edit "$number" --add-reviewer "$joined" \
        && echo "✅ Reviewers requested: $joined"
    fi
  else
    read -rp "Reviewer username(s), comma-separated: " reviewer
    [[ -n "$reviewer" ]] && gh pr edit "$number" --add-reviewer "$reviewer" \
      && echo "✅ Reviewer requested: $reviewer"
  fi
}

# ─── Edit PR title/body ──────────────────────────────────────────

_gpr_edit() {
  local number="$1"

  local field
  field=$(printf '%s\n' "Title" "Body (description)" \
    | fzf --disabled --bind 'q:abort,-:abort' \
        --header="Edit PR #${number}  │  ↑↓ nav  enter select  -/q back" \
        --height=5 --no-info)

  [[ -z "$field" ]] && return

  case "$field" in
    "Title")
      local current
      current=$(gh pr view "$number" --json title -q .title)
      read -rp "New title [$current]: " new_title
      new_title="${new_title:-$current}"
      gh pr edit "$number" --title "$new_title"
      echo "✅ Title updated"
      ;;
    *"Body"*)
      local tmpfile
      tmpfile=$(mktemp /tmp/pr-body-XXXXXX.md)
      gh pr view "$number" --json body -q .body > "$tmpfile"
      ${EDITOR:-vi} "$tmpfile"
      gh pr edit "$number" --body-file "$tmpfile"
      rm -f "$tmpfile"
      echo "✅ Description updated"
      ;;
  esac
}


# ─────────────────────────────────────────────────────────────────
#  ghsecrets — Repository & Environment Secrets
# ─────────────────────────────────────────────────────────────────

ghsecrets() {
  __gh_check || return 1

  local action
  action=$(printf '%s\n' \
    "🔑 List repo secrets" \
    "➕ Set repo secret" \
    "🗑  Delete repo secret" \
    "─────────────────────────────" \
    "🌍 List environment secrets" \
    "➕ Set environment secret" \
    "🗑  Delete environment secret" \
    | fzf --disabled --bind 'q:abort,-:abort' \
        --header="Secrets Management (values are write-only)  │  ↑↓ nav  enter select  -/q back" \
        --height=10 --no-info)

  [[ -z "$action" || "$action" == *"───"* ]] && return

  case "$action" in
    *"List repo secrets"*)
      while true; do
        echo ""
        echo "━━━ Repository Secrets ━━━"
        echo ""
        gh secret list 2>/dev/null || echo "  (none)"
        echo ""
        echo "  ℹ  Values are hidden by design — only names and last updated shown"
        local key; echo ""; read -rsn1 -p "  r=refresh  -/q=back " key; echo ""
        [[ "$key" == "r" || "$key" == "R" ]] || break
      done
      ghsecrets
      ;;

    *"Set repo secret"*)
      read -rp "Secret name (e.g. API_KEY): " name
      if [[ -n "$name" ]]; then
        name=$(echo "$name" | tr '[:lower:]' '[:upper:]')
        echo "Paste the value (input is hidden):"
        gh secret set "$name"
        echo "✅ Secret '$name' saved"
      fi
      ghsecrets
      ;;

    *"Delete repo secret"*)
      local secrets
      secrets=$(gh secret list --json name --jq '.[].name' 2>/dev/null)
      if [[ -z "$secrets" ]]; then
        echo "No repo secrets found."
        sleep 1
        ghsecrets
        return
      fi
      local secret
      secret=$(echo "$secrets" \
        | fzf --header="Select secret to delete  │  type to filter  esc=back")
      if [[ -n "$secret" ]]; then
        read -rp "Delete '$secret'? This cannot be undone. (y/N): " confirm
        [[ "$confirm" =~ ^[yY]$ ]] && gh secret delete "$secret" && echo "✅ Deleted: $secret"
      fi
      ghsecrets
      ;;

    *"List environment secrets"*)
      local env
      env=$(__ghenv_pick "Select environment to view secrets")
      [[ -z "$env" ]] && { ghsecrets; return; }
      while true; do
        echo ""
        echo "━━━ Secrets for environment: $env ━━━"
        echo ""
        gh secret list --env "$env" 2>/dev/null || echo "  (none)"
        local key; echo ""; read -rsn1 -p "  r=refresh  -/q=back " key; echo ""
        [[ "$key" == "r" || "$key" == "R" ]] || break
      done
      ghsecrets
      ;;

    *"Set environment secret"*)
      local env
      env=$(__ghenv_pick "Select environment")
      [[ -z "$env" ]] && { ghsecrets; return; }
      read -rp "Secret name: " name
      if [[ -n "$name" ]]; then
        name=$(echo "$name" | tr '[:lower:]' '[:upper:]')
        echo "Paste the value (input is hidden):"
        gh secret set "$name" --env "$env"
        echo "✅ Secret '$name' saved to environment '$env'"
      fi
      ghsecrets
      ;;

    *"Delete environment secret"*)
      local env
      env=$(__ghenv_pick "Select environment")
      [[ -z "$env" ]] && { ghsecrets; return; }
      local secrets
      secrets=$(gh secret list --env "$env" --json name --jq '.[].name' 2>/dev/null)
      if [[ -z "$secrets" ]]; then
        echo "No secrets in environment '$env'."
        sleep 1
        ghsecrets
        return
      fi
      local secret
      secret=$(echo "$secrets" \
        | fzf --header="Select secret to delete from '$env'  │  esc=back")
      if [[ -n "$secret" ]]; then
        read -rp "Delete '$secret' from '$env'? (y/N): " confirm
        [[ "$confirm" =~ ^[yY]$ ]] && gh secret delete "$secret" --env "$env" \
          && echo "✅ Deleted: $secret from $env"
      fi
      ghsecrets
      ;;
  esac
}


# ─────────────────────────────────────────────────────────────────
#  ghenv — Environment Management
# ─────────────────────────────────────────────────────────────────

# Shared picker used by ghsecrets too
__ghenv_pick() {
  local header="${1:-Select environment}"
  local repo
  repo=$(__gh_repo)
  local envs
  envs=$(gh api "repos/$repo/environments" --jq '.environments[].name' 2>/dev/null)
  if [[ -z "$envs" ]]; then
    echo "No environments found. Use ghenv to create one." >&2
    return 1
  fi
  echo "$envs" | fzf --header="$header  │  type to filter  esc=back" --height=10
}

ghenv() {
  __gh_check || return 1

  local repo
  repo=$(__gh_repo)

  local action
  action=$(printf '%s\n' \
    "📋 List environments" \
    "🔍 View environment details" \
    "➕ Create environment" \
    "⏱  Set wait timer" \
    "👤 Set required reviewers" \
    "🗑  Delete environment" \
    | fzf --disabled --bind 'q:abort,-:abort' \
        --header="Environment Management — $repo  │  ↑↓ nav  enter select  -/q back" \
        --height=9 --no-info)

  [[ -z "$action" ]] && return

  case "$action" in
    *"List environments"*)
      while true; do
        echo ""
        echo "━━━ Environments ━━━"
        echo ""
        gh api "repos/$repo/environments" \
          --jq '.environments[] | "  \(.name)   created: \(.created_at[:10])"' 2>/dev/null \
          || echo "  No environments configured"
        local key; echo ""; read -rsn1 -p "  r=refresh  -/q=back " key; echo ""
        [[ "$key" == "r" || "$key" == "R" ]] || break
      done
      ghenv
      ;;

    *"View environment details"*)
      local env
      env=$(__ghenv_pick "View details for which environment?")
      [[ -z "$env" ]] && { ghenv; return; }
      while true; do
        echo ""
        echo "━━━ Environment: $env ━━━"
        echo ""
        echo "Protection rules:"
        gh api "repos/$repo/environments/$env" \
          --jq '
            if (.protection_rules | length) == 0 then "  (none)"
            else .protection_rules[] |
              if .type == "wait_timer" then "  ⏱  Wait timer: \(.wait_timer) minutes"
              elif .type == "required_reviewers" then "  👤 Required reviewers: \([.reviewers[].reviewer.login] | join(", "))"
              else "  \(.type)"
              end
            end' 2>/dev/null || echo "  (none)"
        echo ""
        echo "Secrets:"
        gh secret list --env "$env" 2>/dev/null | sed 's/^/  /' || echo "  (none)"
        local key; echo ""; read -rsn1 -p "  r=refresh  -/q=back " key; echo ""
        [[ "$key" == "r" || "$key" == "R" ]] || break
      done
      ghenv
      ;;

    *"Create environment"*)
      read -rp "Environment name: " name
      if [[ -n "$name" ]]; then
        gh api -X PUT "repos/$repo/environments/$name" --silent 2>/dev/null \
          && echo "✅ Environment '$name' created" \
          || echo "❌ Failed — check permissions"
      fi
      ghenv
      ;;

    *"Set wait timer"*)
      local env
      env=$(__ghenv_pick "Set wait timer for which environment?")
      [[ -z "$env" ]] && { ghenv; return; }
      read -rp "Wait time in minutes (0-43200, 0 to disable): " minutes
      if [[ "$minutes" =~ ^[0-9]+$ ]]; then
        gh api -X PUT "repos/$repo/environments/$env" \
          --input <(jq -n --argjson m "$minutes" \
            '{wait_timer: $m}') --silent 2>/dev/null \
          && echo "✅ Wait timer set to ${minutes}m for '$env'" \
          || echo "❌ Failed — check permissions"
      fi
      ghenv
      ;;

    *"Set required reviewers"*)
      local env
      env=$(__ghenv_pick "Set reviewers for which environment?")
      [[ -z "$env" ]] && { ghenv; return; }

      local collabs
      collabs=$(gh api "repos/$repo/collaborators" --jq '.[].login' 2>/dev/null)

      local reviewer
      if [[ -n "$collabs" ]]; then
        reviewer=$(echo "$collabs" \
          | fzf --header="Select reviewer  │  type to filter  esc=back")
      fi
      if [[ -z "$reviewer" ]]; then
        read -rp "Reviewer username: " reviewer
      fi

      if [[ -n "$reviewer" ]]; then
        local user_id
        user_id=$(gh api "users/$reviewer" --jq '.id' 2>/dev/null)
        if [[ -n "$user_id" ]]; then
          gh api -X PUT "repos/$repo/environments/$env" \
            --input <(jq -n --argjson uid "$user_id" \
              '{reviewers: [{type: "User", id: $uid}]}') --silent 2>/dev/null \
            && echo "✅ Reviewer '$reviewer' set for '$env'" \
            || echo "❌ Failed — check permissions"
        else
          echo "❌ User '$reviewer' not found on GitHub"
        fi
      fi
      ghenv
      ;;

    *"Delete environment"*)
      local env
      env=$(__ghenv_pick "Delete which environment?")
      [[ -z "$env" ]] && { ghenv; return; }
      read -rp "⚠️  Delete environment '$env'? This removes all its secrets too. (y/N): " confirm
      if [[ "$confirm" =~ ^[yY]$ ]]; then
        gh api -X DELETE "repos/$repo/environments/$env" --silent 2>/dev/null \
          && echo "✅ Environment '$env' deleted" \
          || echo "❌ Failed — check permissions"
      fi
      ghenv
      ;;
  esac
}


# ─────────────────────────────────────────────────────────────────
#  ghbranch — Branch Management & Protection
# ─────────────────────────────────────────────────────────────────

ghbranch() {
  __gh_check || return 1

  local repo
  repo=$(__gh_repo)

  local action
  action=$(printf '%s\n' \
    "📋 List branches (with protection status)" \
    "🛡  View protection rules" \
    "🛡  Set protection rules" \
    "🗑  Remove protection" \
    "🗑  Delete remote branch" \
    "⭐ Set default branch" \
    | fzf --disabled --bind 'q:abort,-:abort' \
        --header="Branch Management — $repo  │  ↑↓ nav  enter select  -/q back" \
        --height=9 --no-info)

  [[ -z "$action" ]] && return

  case "$action" in
    *"List branches"*)
      while true; do
        echo ""
        echo "━━━ Branches ━━━"
        echo ""
        gh api "repos/$repo/branches" --paginate \
          --jq '.[] | "  \(if .protected then "🛡 " else "   " end)\(.name)\(if .protected then "  (protected)" else "" end)"' \
          2>/dev/null || echo "  Failed to fetch branches"
        echo ""
        echo "  🛡  = branch protection rules enabled"
        local key; echo ""; read -rsn1 -p "  r=refresh  -/q=back " key; echo ""
        [[ "$key" == "r" || "$key" == "R" ]] || break
      done
      ghbranch
      ;;

    *"View protection"*)
      local branch
      branch=$(__gh_pick_branch "View protections for which branch?")
      [[ -z "$branch" ]] && { ghbranch; return; }
      while true; do
        echo ""
        echo "━━━ Protection rules: $branch ━━━"
        echo ""
        gh api "repos/$repo/branches/$branch/protection" 2>/dev/null \
          | jq '{
            required_approving_reviews: (.required_pull_request_reviews.required_approving_review_count // "not set"),
            dismiss_stale_reviews: (.required_pull_request_reviews.dismiss_stale_reviews // false),
            require_status_checks: (.required_status_checks.strict // false),
            required_checks: [(.required_status_checks.contexts // [])[]],
            enforce_admins: (.enforce_admins.enabled // false),
            require_linear_history: (.required_linear_history.enabled // false),
            allow_force_pushes: (.allow_force_pushes.enabled // false),
            allow_deletions: (.allow_deletions.enabled // false)
          }' 2>/dev/null || echo "  No protection rules set on '$branch'"
        local key; echo ""; read -rsn1 -p "  r=refresh  -/q=back " key; echo ""
        [[ "$key" == "r" || "$key" == "R" ]] || break
      done
      ghbranch
      ;;

    *"Set protection"*)
      _ghbranch_protect "$repo"
      ghbranch
      ;;

    *"Remove protection"*)
      local branch
      branch=$(__gh_pick_branch "Remove protection from which branch?")
      [[ -z "$branch" ]] && { ghbranch; return; }
      read -rp "⚠️  Remove ALL protection rules from '$branch'? (y/N): " confirm
      if [[ "$confirm" =~ ^[yY]$ ]]; then
        gh api -X DELETE "repos/$repo/branches/$branch/protection" --silent 2>/dev/null \
          && echo "✅ Protection removed from '$branch'" \
          || echo "❌ Failed — branch may not be protected, or check permissions"
      fi
      ghbranch
      ;;

    *"Delete remote"*)
      local default_branch
      default_branch=$(__gh_default_branch)
      local branch
      branch=$(__gh_pick_branch "Delete which remote branch?")
      [[ -z "$branch" ]] && { ghbranch; return; }
      if [[ "$branch" == "$default_branch" ]]; then
        echo "❌ Cannot delete the default branch ('$default_branch')"
        sleep 1
        ghbranch
        return
      fi
      read -rp "Delete remote branch '$branch'? (y/N): " confirm
      if [[ "$confirm" =~ ^[yY]$ ]]; then
        git push origin --delete "$branch" 2>/dev/null \
          && echo "✅ Remote branch '$branch' deleted" \
          || echo "❌ Failed to delete '$branch'"
      fi
      ghbranch
      ;;

    *"Set default"*)
      local branch
      branch=$(__gh_pick_branch "Set which branch as default?")
      [[ -z "$branch" ]] && { ghbranch; return; }
      read -rp "Set '$branch' as default branch? (y/N): " confirm
      if [[ "$confirm" =~ ^[yY]$ ]]; then
        gh repo edit --default-branch "$branch" 2>/dev/null \
          && echo "✅ Default branch set to '$branch'" \
          || echo "❌ Failed — check permissions"
      fi
      ghbranch
      ;;
  esac
}

# ─── Interactive branch protection setup ──────────────────────────

_ghbranch_protect() {
  local repo="$1"

  local branch
  branch=$(__gh_pick_branch "Protect which branch?")
  [[ -z "$branch" ]] && return

  echo ""
  echo "━━━ Configure protection for '$branch' ━━━"
  echo ""

  local reviews=0
  read -rp "Required approving reviews (0-6, default 0): " reviews
  reviews=${reviews:-0}

  local dismiss_stale="false"
  if (( reviews > 0 )); then
    read -rp "Dismiss stale reviews on new push? (Y/n): " ds
    [[ ! "$ds" =~ ^[nN]$ ]] && dismiss_stale="true"
  fi

  local strict_checks="false"
  read -rp "Require status checks to pass before merging? (y/N): " sc
  [[ "$sc" =~ ^[yY]$ ]] && strict_checks="true"

  local enforce_admins="false"
  read -rp "Enforce rules for admins too? (y/N): " ea
  [[ "$ea" =~ ^[yY]$ ]] && enforce_admins="true"

  local linear="false"
  read -rp "Require linear history? (y/N): " lh
  [[ "$lh" =~ ^[yY]$ ]] && linear="true"

  local payload
  payload=$(jq -n \
    --argjson reviews "$reviews" \
    --argjson dismiss "$dismiss_stale" \
    --argjson strict "$strict_checks" \
    --argjson enforce "$enforce_admins" \
    --argjson linear "$linear" \
    '{
      required_status_checks: (if $strict then {strict: true, contexts: []} else null end),
      enforce_admins: $enforce,
      required_pull_request_reviews: (if $reviews > 0 then {
        required_approving_review_count: $reviews,
        dismiss_stale_reviews: $dismiss
      } else null end),
      restrictions: null,
      required_linear_history: $linear,
      allow_force_pushes: false,
      allow_deletions: false
    }')

  echo ""
  gh api -X PUT "repos/$repo/branches/$branch/protection" \
    --input <(echo "$payload") --silent 2>/dev/null \
    && echo "✅ Protection rules applied to '$branch'" \
    || echo "❌ Failed — check repo permissions (admin access required)"
}
