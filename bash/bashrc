#!/usr/bin/env bash
#~/.bashrc

#####################################################################
# Riley Oest .bashrc
#####################################################################

# ~/.bashrc: executed by bash(1) for non-login shells.
# see /usr/share/doc/bash/examples/startup-files (in the package bash-doc)
# for examples

# If not running interactively, don't do anything
case $- in
    *i*) ;;
      *) return;;
esac

# ─── OS Detection ─────────────────────────────────────────────────
case "$(uname -s)" in
  Darwin) _OS=mac ;;
  *)      _OS=linux ;;
esac

# ─── Global definitions (RHEL/Fedora) ────────────────────────────
# RHEL's /etc/bashrc sets up the module system, /etc/profile.d/*,
# and default environment. Source it early so our config can override.
[[ -f /etc/bashrc ]] && . /etc/bashrc

# ─── History ───────────────────────────────────────────────────────
# don't put duplicate lines or lines starting with space in the history.
# See bash(1) for more options
HISTCONTROL=ignoreboth

shopt -s histappend # append to the history file, don't overwrite it

# for setting history length see HISTSIZE and HISTFILESIZE in bash(1)
HISTSIZE=100000 # in memory (RAM) cache
HISTFILESIZE=100000 # on disk (hard drive) .bash_history


# ─── Shell options ─────────────────────────────────────────────────
# check the window size after each command and, if necessary,
# update the values of LINES and COLUMNS.
shopt -s checkwinsize
shopt -s cdspell        # Auto-correct minor cd typos (e.g. `cd projetcs` → `cd projects`)
if ((BASH_VERSINFO[0] >= 4)); then
  shopt -s dirspell     # Auto-correct directory names during tab completion
  shopt -s globstar     # ** matches files + directories recursively (e.g. `ls **/*.py`)
fi

# ─── Completion ────────────────────────────────────────────────────
# enable programmable completion features (you don't need to enable
# this, if it's already enabled in /etc/bash.bashrc and /etc/profile
# sources /etc/bash.bashrc).
if ! shopt -oq posix; then
  if [ -f /usr/share/bash-completion/bash_completion ]; then
    . /usr/share/bash-completion/bash_completion
  elif [ -f /etc/bash_completion ]; then
    . /etc/bash_completion
  fi
fi

# ─── lesspipe (makes `less` handle binary files) ──────────────────
# make less more friendly for non-text input files, see lesspipe(1)
[ -x /usr/bin/lesspipe ] && eval "$(SHELL=/bin/sh lesspipe)"

# ─── Alert (for long-running commands: `sleep 10; alert`) ────────
unalias alert 2>/dev/null
if [[ "$_OS" == "mac" ]]; then
  alert() {
    local msg
    msg=$(history | tail -n1 | sed 's/^[[:space:]]*[0-9][0-9]*[[:space:]]*//;s/[;&|][[:space:]]*alert$//')
    osascript -e "display notification \"$msg\" with title \"Terminal\""
  }
else
  alert() {
    local icon msg
    icon=$([ $? = 0 ] && echo terminal || echo error)
    msg=$(history | tail -n1 | sed -e 's/^\s*[0-9]\+\s*//;s/[;&|]\s*alert$//')
    notify-send --urgency=low -i "$icon" "$msg"
  }
fi

#####################################################################
# PATH
#####################################################################

export PATH="$HOME/bin:$PATH"

# Homebrew
if [[ "$_OS" == "mac" ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv 2>/dev/null || /usr/local/bin/brew shellenv 2>/dev/null)"
else
  [[ -d "/home/linuxbrew/.linuxbrew" ]] && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# ─── .NET ──────────────────────────────────────────────────────────
export DOTNET_ROOT="$HOME/.dotnet"
export DOTNET_MULTILEVEL_LOOKUP=1
export PATH="$DOTNET_ROOT:$PATH"

# ─── Java ──────────────────────────────────────────────────────────
if [[ "$_OS" == "mac" ]]; then
  export JAVA_HOME=$(/usr/libexec/java_home 2>/dev/null)
elif [[ -d /usr/lib/jvm ]]; then
  # Works on both Debian (-amd64 suffix) and RHEL (no suffix)
  for _jvm in /usr/lib/jvm/java-17-openjdk* /usr/lib/jvm/java-17*; do
    [[ -d "$_jvm" ]] && export JAVA_HOME="$_jvm" && break
  done
  unset _jvm
fi
[[ -n "$JAVA_HOME" ]] && export PATH="$JAVA_HOME/bin:$PATH"

# Machine-local config (env vars needed before package managers init)
[[ -f ~/.bash_roest_local ]] && source ~/.bash_roest_local

#####################################################################
# Package managers (auto-generated blocks — don't manually edit)
#####################################################################

# >>> conda initialize >>>
# Search common conda locations (~/miniconda3 on WSL/mac, ~/tools/miniconda3 on RHEL)
_conda_root=""
for _d in "$HOME/miniconda3" "$HOME/tools/miniconda3" "$HOME/anaconda3"; do
  [[ -x "$_d/bin/conda" ]] && _conda_root="$_d" && break
done
if [[ -n "$_conda_root" ]]; then
  __conda_setup="$("$_conda_root/bin/conda" 'shell.bash' 'hook' 2>/dev/null)"
  if [ $? -eq 0 ]; then
    eval "$__conda_setup"
  else
    if [ -f "$_conda_root/etc/profile.d/conda.sh" ]; then
      . "$_conda_root/etc/profile.d/conda.sh"
    else
      export PATH="$_conda_root/bin:$PATH"
    fi
  fi
  unset __conda_setup
fi
unset _conda_root _d
# <<< conda initialize <<<

# nvm
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

#####################################################################
# Custom config
#####################################################################

source ~/.bash_roest_theme
[[ -f ~/.bash_roest_password_commands ]] && source ~/.bash_roest_password_commands
source ~/.bash_roest_productivity
source ~/.bash_roest_git
source ~/.bash_roest_github
export PATH="$HOME/.local/bin:$PATH"
