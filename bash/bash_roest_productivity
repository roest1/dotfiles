#!/usr/bin/env bash
# ~/.bash_roest_productivity
#
# Source this from .bashrc:
#   source ~/.bash_roest_productivity
#
# Prerequisites (install once):
#   brew install zoxide fzf bat eza
#
# See all custom commands:
#   h           Show quick reference
#   h <command> Show detailed help for a command

# ─── zoxide (smarter cd) ──────────────────────────────────────────────────────
# Learns from your cd habits. After a few days, `z proj` jumps to ~/projects.
#
# How it works: every time you `cd` somewhere, zoxide records the path and
# how often you visit it. `z` uses frecency (frequency + recency) to rank
# matches. It's a drop-in `cd` replacement — you don't change any habits,
# you just type less over time.
#
# Depends on: zoxide (brew install zoxide)
if command -v zoxide &>/dev/null; then
  eval "$(zoxide init bash)"
fi

# ─── fzf (fuzzy everything) ───────────────────────────────────────────────────
# Transforms three built-in keybindings:
#   Ctrl+R  → fuzzy search command history (instead of reverse-i-search)
#   Ctrl+T  → fuzzy file picker, inserts path at cursor
#   Alt+C   → fuzzy cd into a subdirectory
#
# How it works: fzf reads lines from stdin (or a command), presents a
# fuzzy-searchable list, and outputs the selection. The keybindings above
# are shell integrations that pipe history/files/dirs into fzf automatically.
#
# FZF_DEFAULT_COMMAND controls what `fzf` lists when run with no input.
# We point it at `fd` so it respects .gitignore and skips .git/.
#
# Depends on: fzf (brew install fzf), optionally fd for faster file listing
if command -v fzf &>/dev/null; then
  eval "$(fzf --bash 2>/dev/null)" || source /usr/share/bash-completion/completions/fzf 2>/dev/null
  export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border'
  if command -v fd &>/dev/null; then
    export FZF_DEFAULT_COMMAND='fd --type f --hidden --exclude .git'
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
    export FZF_ALT_C_COMMAND='fd --type d --hidden --exclude .git'
  fi
fi

# ─── Git aliases ──────────────────────────────────────────────────────────────
# Muscle-memory shortcuts. `gs` instead of `git status`, etc.
# --force-with-lease is a safer force push (fails if remote has new commits).
# `gb` sorts branches by most recently committed — your active branches first.
alias gs='git status -sb'
alias ga='git add'
alias gaa='git add -A'
alias gc='git commit -m'
alias gca='git commit --amend --no-edit'
alias gp='git push'
alias gpf='git push --force-with-lease'
alias gl='git log --oneline -20'
alias gll='git log --oneline --graph --all -30'
alias gd='git diff'
alias gds='git diff --staged'
alias gco='git checkout'
alias gcb='git checkout -b'
alias gb='git branch --sort=-committerdate'
alias gst='git stash'
alias gstp='git stash pop'

# ─── Better defaults ──────────────────────────────────────────────────────────
# eza: modern ls replacement with git integration and icons.
# bat: cat with syntax highlighting and line numbers.
# On Debian/Ubuntu, bat installs as `batcat` due to a name conflict.
if command -v eza &>/dev/null; then
  alias ls='eza --icons --group-directories-first'
  alias ll='eza -la --icons --group-directories-first --git'
  alias lt='eza -la --icons --tree --level=2 --git-ignore'
else
  alias ll='ls -alFh'
fi

if command -v bat &>/dev/null; then
  alias cat='bat --plain --paging=never'
  alias catn='bat'
elif command -v batcat &>/dev/null; then
  alias cat='batcat --plain --paging=never'
  alias catn='batcat'
fi

# ─── Directory shortcuts ──────────────────────────────────────────────────────

# mkcd: create directory and cd into it in one step
mkcd() {
  mkdir -p "$1" && cd "$1"
}

# up: go up N directories. `up 3` = cd ../../..
up() {
  local d=""
  for ((i = 1; i <= ${1:-1}; i++)); do
    d="../$d"
  done
  cd "$d" || return
}

# ─── Quick file search ────────────────────────────────────────────────────────

# f: find file by name. No args → fzf picker → open in nvim.
# With args → fd search (respects .gitignore).
#
# Depends on: fzf, fd
f() {
  if [[ $# -eq 0 ]]; then
    local file
    file=$(fzf --preview 'head -50 {}' 2>/dev/null)
    [[ -n "$file" ]] && nvim "$file"
  else
    fd --type f "$1"
  fi
}

# ─── Quick project stats ──────────────────────────────────────────────────────

# lines: count lines of code by extension.
# Uses git ls-files when inside a repo (skips generated/ignored files).
#
# Usage: `lines` (total) or `lines py lua ts` (by extension)
lines() {
  if [[ $# -eq 0 ]]; then
    if git rev-parse --is-inside-work-tree &>/dev/null; then
      git ls-files | xargs wc -l 2>/dev/null | tail -1
    else
      find . -type f | head -500 | xargs wc -l 2>/dev/null | tail -1
    fi
  else
    for ext in "$@"; do
      local count
      count=$(find . -name "*.${ext}" -not -path '*/.git/*' -not -path '*/node_modules/*' | xargs wc -l 2>/dev/null | tail -1)
      echo "${ext}: ${count}"
    done
  fi
}

# ─── Process management ──────────────────────────────────────────────────────

# port: show what's running on a given port.
# Uses lsof first (macOS/Linux), falls back to ss (Linux).
port() {
  lsof -i :"$1" 2>/dev/null || ss -tlnp | grep ":$1"
}

# ─── Misc power tools ────────────────────────────────────────────────────────

# c: clear alias
c() {
    clear
}

# ddiff: side-by-side colored diff of two files
ddiff() {
  diff --color=always -y --width="$(tput cols)" "$1" "$2" | less -R
}

# serve: quick HTTP server in current directory
# Depends on: python3
serve() {
  local port="${1:-8000}"
  echo "Serving on http://localhost:${port}"
  python3 -m http.server "$port"
}

# loop: repeatedly run a command with a clear screen (like watch)
# Usage: loop ls -la    (refreshes every 2s)
#        LOOP_INTERVAL=5 loop df -h
loop() {
  while true; do
    clear
    echo "─── $(date) ───"
    eval "$@"
    sleep "${LOOP_INTERVAL:-2}"
  done
}

# findword: rg all occurences
findword() {
    local search_term="$1"
    shift
    local ignore_dirs=""

    # Professional argument parsing for the -I flag
    while [[ "$#" -gt 0 ]]; do
        case $1 in
            -I) ignore_dirs="$2"; shift ;;
            *) echo "Unknown parameter: $1"; return 1 ;;
        esac
        shift
    done

    if [ -z "$search_term" ]; then
        echo "Usage: findword <search_string> [-I 'dir1|dir2']"
        return 1
    fi

    # Initialize the command array to avoid shell expansion issues
    local rg_args=(
        --column
        --line-number
        --no-heading
        --color=always
        --smart-case
        --word-regexp # This is the same as \b...\b but cleaner
        --hidden
    )

    # Standard excludes
    for pattern in ".git" "node_modules" "bin" "obj"; do
        rg_args+=(--glob "!**/$pattern/*")
    done

    # Custom excludes from the -I flag
    if [ -n "$ignore_dirs" ]; then
        IFS='|' read -ra DIRS <<< "$ignore_dirs"
        for dir in "${DIRS[@]}"; do
            # We use !**/$dir/** to prune the directory tree entirely
            rg_args+=(--glob "!**/$dir/**")
        done
    fi

    # Final execution
    rg "${rg_args[@]}" "$search_term"
}


# extract: Universal archive extractor
extract() {
    if [ -f "$1" ]; then
        case "$1" in
            *.tar.bz2)   tar xjf "$1"     ;;
            *.tar.gz)    tar xzf "$1"     ;;
            *.bz2)       bunzip2 "$1"     ;;
            *.rar)       unrar x "$1"     ;;
            *.gz)        gunzip "$1"      ;;
            *.tar)       tar xf "$1"      ;;
            *.tbz2)      tar xjf "$1"     ;;
            *.tgz)       tar xzf "$1"     ;;
            *.zip)       unzip "$1"       ;;
            *.Z)         uncompress "$1"  ;;
            *.7z)        7z x "$1"        ;;
            *)           echo "'$1' cannot be extracted via extract()" ;;
        esac
    else
        echo "'$1' is not a valid file"
    fi
}

# edit/reload dotfiles (symlinked by install.sh)
dotfiles-edit() {
    local dotdir
    dotdir="$(cd "$(dirname "$(readlink -f ~/.bashrc 2>/dev/null || readlink ~/.bashrc)")" && pwd)"
    nvim "$dotdir"
}

reload() {
    source ~/.bashrc
    echo "Reloaded ~/.bashrc"
}

