      local tools=(zoxide fzf bat eza rg fd nvim dotnet gh jq)
      local missing=()
      
      for cmd in "${tools[@]}"; do
        local display_name=$cmd
        local found=false
        
        # Special check logic for variations
        if [[ "$cmd" == "bat" ]] && command -v batcat &>/dev/null; then
          found=true
        elif [[ "$cmd" == "rg" ]] && command -v rg &>/dev/null; then
          found=true
        elif command -v "$cmd" &>/dev/null; then
          found=true
        fi

        if [ "$found" = true ]; then
          printf "  \033[32m%-10s ✅ Installed\033[0m\n" "$display_name"
        else
          printf "  \033[31m%-10s ❌ Missing\033[0m\n" "$display_name"
          # Map 'rg' back to 'ripgrep' for the install hint
          [[ "$cmd" == "rg" ]] && missing+=("ripgrep") || missing+=("$cmd")
        fi
      done

      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
      
      if [ ${#missing[@]} -eq 0 ]; then
        echo -e "\033[32mAll dependencies met! Your productivity is at 100%.\033[0m"
      else
        echo -e "\033[1;33mTo install missing tools:\033[0m"
        echo "  brew install ${missing[*]}"
      fi

      cat <<'HELP'

Tool Descriptions:
  zoxide    Smart cd replacement (learns your habits)
  fzf       Fuzzy finder (Ctrl+R history, Ctrl+T files)
  bat       cat with syntax highlighting
  eza       Modern ls with icons and git integration
  rg/fd     High-speed search replacements for grep/find
  gh        GitHub CLI (must run: gh auth login)
  jq        JSON processor (used by GitHub interactive commands)
HELP
      ;;
    *)
      echo "No help found for '$1'. Run 'h' to see all commands."
      ;;
  esac
}
